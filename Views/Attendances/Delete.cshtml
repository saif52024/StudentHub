@model StudentHub.Models.Attendance
@{
    ViewData["Title"] = "Delete Attendance";
}

<div class="container py-4">
    <h2 class="text-center text-danger mb-4">Delete Attendance Record</h2>

    <div class="glass p-4">
        <h5>Are you sure you want to delete this record?</h5>

        <dl class="row mt-3">
            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9">@Model.Student?.Name</dd>

            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.Date.ToString("dd MMM yyyy")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="@(Model.Status == "Present" ? "text-success" : "text-danger")">@Model.Status</span>
            </dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="AttendanceId" />
            <div class="text-center mt-4">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>
