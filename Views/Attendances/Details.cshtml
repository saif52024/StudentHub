@model StudentHub.Models.Attendance
@{
    ViewData["Title"] = "Attendance Details";
}

<div class="container py-4">
    <h2 class="text-center text-info mb-4">Attendance Details</h2>

    <div class="glass p-4">
        <dl class="row">
            <dt class="col-sm-3">Student</dt>
            <dd class="col-sm-9">@Model.Student?.Name</dd>

            <dt class="col-sm-3">Date</dt>
            <dd class="col-sm-9">@Model.Date.ToString("dd MMM yyyy")</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="@(Model.Status == "Present" ? "text-success fw-bold" : "text-danger fw-bold")">
                    @Model.Status
                </span>
            </dd>
        </dl>

        <div class="text-center mt-4">
            <a asp-action="Edit" asp-route-id="@Model.AttendanceId" class="btn btn-primary">Edit</a>
            <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
        </div>
    </div>
</div>
