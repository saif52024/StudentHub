@{
    ViewData["Title"] = "Welcome";
}

<div class="d-flex flex-column align-items-center justify-content-center text-center" style="min-height: 90vh;">
    <!-- Hero Section -->
    <div class="glass p-5 text-center" style="max-width: 700px;">
        <h1 class="display-5 fw-bold text-white mb-3">
            Welcome to <span style="color:#00c6ff;">StudentHub</span>
        </h1>
        <p class="text-secondary mb-4" style="font-size: 1.1rem;">
            Your all-in-one digital platform for managing student data, performance, and attendance
            with simplicity and style.
        </p>
        <a href="/Dashboard" class="btn btn-lg mt-2">
            Get Started
        </a>
    </div>

    <!-- Features Section -->
    <div class="container text-center mt-5">
        <div class="row justify-content-center g-4">
            <div class="col-md-3">
                <div class="glass py-4 px-3 h-100">
                    <i class="bi bi-people fs-1 mb-3 text-info"></i>
                    <h5 class="text-white">Student Management</h5>
                    <p class="text-secondary small">Manage student profiles, departments, and contact information easily.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="glass py-4 px-3 h-100">
                    <i class="bi bi-bar-chart-line fs-1 mb-3 text-info"></i>
                    <h5 class="text-white">Marks & GPA</h5>
                    <p class="text-secondary small">Record marks, compute percentages, and view academic performance.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="glass py-4 px-3 h-100">
                    <i class="bi bi-calendar-check fs-1 mb-3 text-info"></i>
                    <h5 class="text-white">Attendance</h5>
                    <p class="text-secondary small">Track attendance records and generate insights into student presence.</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="glass py-4 px-3 h-100">
                    <i class="bi bi-speedometer2 fs-1 mb-3 text-info"></i>
                    <h5 class="text-white">Analytics</h5>
                    <p class="text-secondary small">Visualize data and make data-driven academic decisions with clarity.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Bootstrap Icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet" />
