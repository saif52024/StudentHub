@model IEnumerable<StudentHub.Models.Student>
@{
    ViewData["Title"] = "Students";
}

<div class="container py-4">
    <h1 class="mb-4 text-center text-info">Student Management</h1>

    <div class="mb-3 text-end">
        <a asp-action="Create" class="btn btn-primary">+ Add New Student</a>
    </div>

    <div class="glass p-4">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Age</th>
                    <th>Gender</th>
                    <th>Semester</th>
                    <th>Contact</th>
                    <th>Department</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model)
                {
                    <tr>
                        <td>@student.Name</td>
                        <td>@student.Age</td>
                        <td>@student.Gender</td>
                        <td>@student.Semester</td>
                        <td>@student.Contact</td>
                        <td>@student.Department?.DepartmentName</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@student.StudentId" class="btn btn-sm">Edit</a>
                            <a asp-action="Details" asp-route-id="@student.StudentId" class="btn btn-sm">Details</a>
                            <a asp-action="Delete" asp-route-id="@student.StudentId" class="btn btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
