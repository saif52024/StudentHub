@model StudentHub.Models.Mark
@{
    ViewData["Title"] = "Delete Mark";
}

<div class="container py-4">
    <h2 class="text-center text-danger mb-4">Delete Mark</h2>

    <div class="glass p-4">
        <h5>Are you sure you want to delete <span class="text-info">@Model.SubjectName</span> for <span class="fw-bold">@Model.Student?.Name</span>?</h5>

        <dl class="row mt-3">
            <dt class="col-sm-3">Marks</dt>
            <dd class="col-sm-9">@Model.MarksObtained / @Model.TotalMarks</dd>
        </dl>

        <form asp-action="Delete">
            <input type="hidden" asp-for="MarkId" />
            <div class="text-center mt-4">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>
